.idea/

# The .vscode folder contains launch configuration and tasks you configure in
# VS Code which you may wish to be included in version control, so this line
# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
/build/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# manual git ignores below — credentials, signing, dev-only

# Firebase config files (per-app secrets)
/ios/Runner/GoogleService-Info.plist
/android/app/google-services.json
/ios/Flutter/EnvKeys.xcconfig

# Credentials — sourced exclusively via --dart-define-from-file=.env.json
# (consumed at compile time by lib/env.dart). Never commit real values.
.env.json
.env

# Release signing — keystore lives outside the repo at
# ~/Prash_M4/awarself-creds/kpopchat/upload-keystore.jks; key.properties
# holds the (absolute) path + passwords and is per-machine.
/android/key.properties
/android/app/upload-keystore.jks
*.keystore
*.jks

# Dev/admin-only paths — gated behind admin user / kDebugMode, not shipped
# in release builds. Kept out of source so personal Telegram chat IDs and
# AI-post-generation tooling stay local.
/lib/data/repository/data_filter_repo.dart
/lib/admin_controls/

# VS Code — track launch.json (carries the --dart-define-from-file=.env.json
# flag every dev needs) but not the auto-generated settings.json.
.vscode/settings.json